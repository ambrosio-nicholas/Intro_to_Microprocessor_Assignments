'{$STAMP BS2}
'{$PBASIC 2.5}
x VAR Word
y VAR Word
temp VAR Byte
DEBUG CLS,
"     3|      ", CR,
"     2|      ", CR,
"     1|      ", CR,
"------+------", CR,
"-3-2-1| 1 2 3", CR,
"    -2|      ", CR,
"    -3|      ", CR, CR
DO
  DEBUG "Type X coordinate: "
  DEBUGIN SDEC1 x
  DEBUG CR, "Type Y coordinate: "
  DEBUGIN SDEC1 y
  DEBUG CRSRXY, 0, 11, "X BEFORE: ", DEC x
  x = (x * 2) + 6
  DEBUG " | X AFTER: ", DEC x, CR, "Y Before: ", DEC y
  y = 3 - y
  DEBUG " | Y AFTER: ", DEC y
  IF (x > 12) OR (y > 6) THEN ' <--- Add code from here...
    DEBUG CRSRXY, 0, 8, CLRDN, '
    "Enter values from -3 to 3.", CR, '
    "Try again" '
    '
  ELSE
    DEBUG CRSRXY, x, y, "*"
  ENDIF
  DEBUG CRSRXY, x, y, "*"
  DEBUG CRSRXY, 0, 10, "Press any Key..."
  DEBUGIN temp
  DEBUG CRSRXY, 0, 8, CLRDN
LOOP
'-----------------------------------------
'Coords: Before | After
'        (3,1)  | (12,2)
'        (-2,-2)| (2,5)